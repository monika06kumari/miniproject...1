# ==============================================================================
# .env.example
# ==============================================================================
# This is a template file. Rename this file to `.env` and fill in your actual 
# values before running the application locally.
# IMPORTANT: NEVER commit your actual `.env` file to version control (GitHub).
# ==============================================================================

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Get these from your Supabase Project Settings -> API
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-anon-or-service-role-key-here"

# ── AI Integration (Google Gemini) ────────────────────────────────────────────
# Get this from Google AI Studio
GEMINI_API_KEY="your-gemini-api-key-here"

# ── Nexus Admin Settings ──────────────────────────────────────────────────────
# Default admin account email
NEXUS_ADMIN_EMAIL="admin@nexus.ai"

# Default admin password hash (optional in dev, defaults to legacy check if empty)
NEXUS_ADMIN_PASS_HASH=""

# ── Server Config ─────────────────────────────────────────────────────────────
# Set to "false" in production to disable API docs (/docs and /redoc)
NEXUS_DEV=true
